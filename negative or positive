#include <stdio.h>

int main() {
    double num;
    printf("Enter a number: ");
    scanf("%lf", &num); // Use %lf for double or %d for int

    if (num > 0.0)
        printf("The number is positive.");
    else if (num < 0.0)
        printf("The number is negative.");
    else
        printf("The number is zero.");

    return 0;
}
