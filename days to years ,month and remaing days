#include <stdio.h>

int main() {
    int total_days, years, months, days;

    // Prompt user for input
    printf("Enter total number of days: ");
    scanf("%d", &total_days);

    // Calculate years
    years = total_days / 365;

    // Calculate months from the remaining days after years are removed
    months = (total_days % 365) / 30;

    // Calculate remaining days after years and months are removed
    days = (total_days % 365) % 30;

    // Display the result
    printf("%d days is equivalent to:\n", total_days);
    printf("%d Year(s), %d Month(s), and %d Day(s)\n", years, months, days);

    return 0;
}
